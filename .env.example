# Revolut → YNAB Importer configuration
#
# Copy this file to `.env` (same directory as revolut_to_ynab.py) and fill in your
# values. The `.env` file is git-ignored and never committed.
#
#   cp .env.example .env
#
# Shell-exported variables take precedence over anything in this file.

# ─── Core YNAB (required) ───────────────────────────────────────────────────
# Personal Access Token from app.ynab.com → Account Settings → Developer Settings
YNAB_TOKEN=
# Budget that contains your Revolut account (find with --list-budgets)
YNAB_BUDGET_ID=
# YNAB account ID for your Revolut account (find with --list-accounts)
YNAB_ACCOUNT_ID=

# ─── Crypto portfolio sync (optional, for --crypto-sync) ────────────────────
# YNAB tracking account ID for crypto portfolio
YNAB_CRYPTO_ACCOUNT_ID=
# Bitcoin extended public key (xpub) from Ledger Live → Advanced → xpub
CRYPTO_BTC_XPUB=
# Ethereum address (queries native ETH + AAVE/USDC/USDT/aUSDT balances)
CRYPTO_ETH_ADDRESS=
# Optional: Ankr Web3 API key — prepends an authenticated RPC to the fallback list
ANKR_API_KEY=

# ─── Interactive Brokers sync (optional, for --brokerage-sync) ──────────────
# YNAB tracking account ID for your brokerage
YNAB_BROKERAGE_ACCOUNT_ID=
# IB Client Portal Gateway URL (default: https://localhost:5050)
IBKR_BASE_URL=https://localhost:5050
# IB account ID (e.g. U1234567). Auto-detected from the gateway if omitted.
IBKR_ACCOUNT_ID=

# ─── Telegram Bot (optional, for revolut_ynab_bot.py) ──────────────────────
# Create a bot via @BotFather on Telegram → copy the token
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID — this is the bot admin who approves new users
# Send /start to @userinfobot on Telegram → copy your numeric user ID
TELEGRAM_ADMIN_ID=
# Directory for bot databases (user settings + per-user transaction DBs)
# Default: ./bot_data/
# BOT_DATA_DIR=./bot_data

# ─── Web UI (optional, for revolut_ynab_bot.py) ─────────────────────────────
# Set WEB_UI_ENABLED=1 to start the FastAPI server alongside the bot.
# WEB_UI_ENABLED=0
# Host/port the web server binds to inside the container. The default
# 0.0.0.0:8080 is reachable by the cloudflared sidecar over the compose
# network and NOT exposed on the host (no `ports:` block in compose by
# default). Don't change unless you know what you're doing.
# WEB_UI_HOST=0.0.0.0
# WEB_UI_PORT=8080
# Public URL the bot will tell users to open after they run /login. Use
# whatever your cloudflared tunnel hostname resolves to (or your own
# reverse-proxy URL). Don't include a trailing slash.
# WEB_UI_PUBLIC_URL=https://your-tunnel-hostname.example.com
# Secret used to sign session cookies. Generate with:
#     python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# REQUIRED when WEB_UI_ENABLED=1.
# WEB_UI_SECRET_KEY=
# How long a /login URL is valid before it must be regenerated (seconds).
# Default: 300 (5 minutes).
# WEB_UI_LOGIN_TTL=300
# How long a logged-in session stays alive without activity (seconds).
# Default: 1800 (30 minutes).
# WEB_UI_SESSION_TTL=1800
# Optional comma-separated IP allowlist for the web server. Empty = any IP.
# Useful if you don't trust the tunnel layer alone (e.g. require also being
# on a corporate VPN). Example: WEB_UI_ALLOWED_IPS=10.0.0.0/8,192.168.1.0/24
# WEB_UI_ALLOWED_IPS=

# ─── Logging (optional) ─────────────────────────────────────────────────────
# Log every transaction created / updated / reconciled plus crypto & brokerage
# syncs. Leave LOG_FILE empty to disable file logging.
#
# Log level: DEBUG, INFO (default), WARNING, ERROR
LOG_LEVEL=INFO
# Path to the log file. `~` is expanded. Default when unset: ~/.revolut_to_ynab.log
LOG_FILE=~/.revolut_to_ynab.log

# ─── Auto-detect latest Revolut CSV (optional) ──────────────────────────────
# When you run the script without a CSV argument, it looks here for the newest
# `account-statement_*.csv` (ranked by the 2nd date in the filename, which is
# typically the export date). Default: ~/Downloads
CSV_DIR=~/Downloads
